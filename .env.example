# SQLite 数据库文件位置
DATABASE_URL=./storage/db/blog.sqlite

# 管理后台会话密钥，生产环境请替换为高强度随机串
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
# 管理员登录密码
ADMIN_PASSWORD=change-me-now
# 是否跳过后台登录校验，生产环境务必保持 false
ADMIN_BYPASS_LOGIN=false
# 是否启用后台入口
ENABLE_ADMIN=true

# SMTP 授权码，只放 .env，不再写入运行时 JSON
SMTP_PASS=

# 站点主域名，收录脚本会优先读取
NEXT_PUBLIC_SITE_URL=https://example.com
# 兼容脚本读取的站点地址
SITE_URL=https://example.com

# 百度主动推送 Token
BAIDU_PUSH_TOKEN=
# IndexNow Key
INDEXNOW_KEY=
